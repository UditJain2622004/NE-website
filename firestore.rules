rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // Patients — server-only (Admin SDK bypasses rules)
    // ──────────────────────────────────────────────
    match /patients/{phone} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────
    // Doctors — public read, server-only write
    // ──────────────────────────────────────────────
    match /doctors/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // Doctor Leaves — public read (calendar display), server-only write
    // ──────────────────────────────────────────────
    match /doctorLeaves/{leaveId} {
      allow read: if true;
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // Doctor Slots — public read (availability), server-only write
    // ──────────────────────────────────────────────
    match /doctorSlots/{slotId} {
      allow read: if true;
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // Appointments — authenticated users read, server-only write
    // ──────────────────────────────────────────────
    match /appointments/{apptId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // Users — authenticated user reads own doc only
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
